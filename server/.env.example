# 数据库
DB_HOST=localhost
DB_USER=kiroo
DB_PASSWORD=请填入数据库密码
DB_NAME=kiroo_assessment

# JWT密钥（请更换为随机字符串）
JWT_SECRET=请生成一个随机字符串替换这里
ADMIN_JWT_SECRET=请生成另一个随机字符串替换这里

# DeepSeek
DEEPSEEK_API_KEY=sk-你的key

# 端口
PORT=3000

# 腾讯云短信服务（Phase 2 配置）
SMS_ENABLED=false
SMS_SECRET_ID=你的腾讯云SecretId
SMS_SECRET_KEY=你的腾讯云SecretKey
SMS_SDK_APP_ID=你的短信应用ID
SMS_SIGN_NAME=你的短信签名
SMS_TEMPLATE_ID=你的验证码模板ID
