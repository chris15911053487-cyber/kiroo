{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MIDS-F2 Report Output Schema",
  "type": "object",
  "required": ["uniqueGene", "frameworkExplanation", "dimensionOverview", "comprehensiveOverview", "dimensionInsights", "barrelPrinciple", "developmentSuggestions", "summary"],
  "properties": {
    "uniqueGene": {
      "type": "string",
      "minLength": 8,
      "maxLength": 50,
      "description": "独特基因标签——一句话定义这个人最核心的天赋组合。如：'逆商与灰度驱动的领军接班者'。整份报告的文眼，放第一章最前面。"
    },
    "frameworkExplanation": {
      "type": "string",
      "minLength": 50,
      "maxLength": 300,
      "description": "第一章正文——不像展览前言，像朋友的诊断结论。直接说出他最独特的组合是什么，用一个贯穿性的比喻收尾。"
    },
    "dimensionOverview": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "description": "五维雷达图速查定位表——每个维度一行，得分+人话定位",
      "items": {
        "type": "object",
        "required": ["dimensionKey", "dimensionName", "score", "position"],
        "properties": {
          "dimensionKey": { "type": "string", "enum": ["strategic_breakthrough", "execution_disruption", "resource_integration", "adversity_quotient", "ethics_vision"] },
          "dimensionName": { "type": "string" },
          "score": { "type": "number", "minimum": 1, "maximum": 5 },
          "position": { "type": "string", "minLength": 10, "maxLength": 60, "description": "人话定位标签。如：'敏锐但待独立——有好眼睛，还没学会自己看地图'" }
        }
      }
    },
    "comprehensiveOverview": {
      "type": "object",
      "required": ["totalScore", "scoreLabel", "overallAssessment", "spfConclusion"],
      "properties": {
        "totalScore": { "type": "number", "minimum": 20, "maximum": 100 },
        "scoreLabel": { "type": "string", "enum": ["卓越", "良好", "基础", "待开发"] },
        "overallAssessment": {
          "type": "string",
          "minLength": 80,
          "maxLength": 350,
          "description": "五维能力画像整体解读——指出结构特征（如'两头稳、中间强、顶层待激活'），一句话概括个性画像，用比喻收尾。"
        },
        "spfConclusion": {
          "type": "object",
          "required": ["sScore", "pScore", "fScore", "decisionPath", "decisionLabel", "reasoning"],
          "properties": {
            "sScore": { "type": "number" },
            "pScore": { "type": "number" },
            "fScore": { "type": "number" },
            "decisionPath": { "type": "string", "enum": ["leading_succession", "independent_startup", "functional_employment", "further_study"] },
            "decisionLabel": { "type": "string" },
            "decisionEmoji": { "type": "string" },
            "reasoning": { "type": "string", "minLength": 30, "maxLength": 300 }
          }
        }
      }
    },
    "dimensionInsights": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["dimensionKey", "dimensionName", "tier", "score", "level", "entryAnalysis", "coreStrength", "growthSpace", "entryHighlights", "careerInsight"],
        "properties": {
          "dimensionKey": { "type": "string", "enum": ["strategic_breakthrough", "execution_disruption", "resource_integration", "adversity_quotient", "ethics_vision"] },
          "dimensionName": { "type": "string" },
          "tier": { "type": "string", "enum": ["顶层·方向感", "中层·落地感", "底层·根基感"] },
          "score": { "type": "number", "minimum": 1, "maximum": 5 },
          "level": { "type": "string", "enum": ["卓越", "良好", "基础", "待开发"] },
          "coreDefinition": { "type": "string", "minLength": 0, "maxLength": 100, "description": "（可选，向后兼容）" },
          "entryAnalysis": {
            "type": "array",
            "description": "全部条目分析——AI的评分依据",
            "items": {
              "type": "object",
              "required": ["sequence", "text", "score", "comment"],
              "properties": {
                "sequence": { "type": "integer" },
                "text": { "type": "string" },
                "score": { "type": "integer", "minimum": 1, "maximum": 5 },
                "comment": { "type": "string", "minLength": 10, "maxLength": 120, "description": "侧重正面解读该条目得分传递的信号" }
              }
            }
          },
          "coreStrength": {
            "type": "string",
            "minLength": 100,
            "maxLength": 350,
            "description": "◈ 您独到的地方——第一句粗体写出核心判断。展开：这个特点意味着什么？在什么场景下有价值？"
          },
          "growthSpace": {
            "type": "string",
            "minLength": 100,
            "maxLength": 350,
            "description": "◈ 您的成长空间——如果该维度有得分1-2分的条目，直接点名。建议交叉引用其他维度的优势来说明为什么这个短板可以被补上。"
          },
          "entryHighlights": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "description": "该维度全部条目的得分列表——仅含序号+原文+得分，不加评语",
            "items": {
              "type": "object",
              "required": ["sequence", "text", "score"],
              "properties": {
                "sequence": { "type": "integer" },
                "text": { "type": "string" },
                "score": { "type": "integer", "minimum": 1, "maximum": 5 }
              }
            }
          },
          "careerInsight": {
            "type": "string",
            "minLength": 60,
            "maxLength": 250,
            "description": "◈ 这个维度对您的真实含义——不写外部建议，写'这个维度在你的人生中到底意味着什么'。直接告诉他基于这个维度的画像，他该往哪个方向走。"
          },
          "analysis": { "type": "string", "minLength": 0, "maxLength": 500, "description": "（向后兼容旧版，新报告不使用）" },
          "impactOnSuccession": { "type": "string", "minLength": 0, "maxLength": 300, "description": "（向后兼容旧版，新报告不使用）" }
        }
      }
    },
    "barrelPrinciple": {
      "type": "object",
      "required": ["longBoards", "shortBoards", "coreCompetitiveness"],
      "description": "木桶原理诊断——跨维度提炼核心竞争力模型",
      "properties": {
        "longBoards": {
          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "description": "长板（核心竞争力）",
          "items": {
            "type": "object",
            "required": ["name", "score", "description"],
            "properties": {
              "name": { "type": "string", "minLength": 4, "maxLength": 30, "description": "长板名称——准确描述即可。如'逆商与灰度优势''执行颠覆力优势'" },
              "score": { "type": "number", "minimum": 0, "maximum": 5 },
              "description": { "type": "string", "minLength": 30, "maxLength": 150, "description": "这个长板具体指什么——为什么它是核心竞争力" }
            }
          }
        },
        "shortBoards": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "description": "短板（需定向补齐）",
          "items": {
            "type": "object",
            "required": ["name", "score", "fixPath"],
            "properties": {
              "name": { "type": "string", "minLength": 4, "maxLength": 30, "description": "短板名称——具体、可识别。如'资源整合力''独立战略判断'" },
              "score": { "type": "number", "minimum": 0, "maximum": 5 },
              "fixPath": { "type": "string", "minLength": 10, "maxLength": 100, "description": "补板路径——有效的补短方式" }
            }
          }
        },
        "coreCompetitiveness": {
          "type": "string",
          "minLength": 30,
          "maxLength": 200,
          "description": "核心竞争力一句话总结——最不可替代的组合是什么。"
        }
      }
    },
    "developmentSuggestions": {
      "type": "object",
      "required": ["integratedJudgment", "developmentDirection", "capabilityImprovements", "supplementarySuggestions", "stakeholderAdvice"],
      "properties": {
        "integratedJudgment": {
          "type": "object",
          "required": ["tierSummary"],
          "properties": {
            "tierSummary": {
              "type": "string",
              "minLength": 50,
              "maxLength": 300,
              "description": "正向总结三层结构——底盘（逆商+格局）→中层（执行+整合）→顶层（战略）各处于什么状态"
            },
            "tierTable": { "type": "string", "minLength": 0, "maxLength": 200, "description": "（可选）" }
          }
        },
        "developmentDirection": {
          "type": "string",
          "minLength": 30,
          "maxLength": 250,
          "description": "整体发展方向——先激活什么、再强化什么，顺序为什么重要"
        },
        "capabilityImprovements": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "object",
            "required": ["dimensionKey", "dimensionName", "direction", "reason"],
            "properties": {
              "dimensionKey": { "type": "string" },
              "dimensionName": { "type": "string" },
              "direction": { "type": "string", "minLength": 10, "maxLength": 150, "description": "用'激活/释放/引爆'等词，附带2-3个具体行动建议" },
              "reason": { "type": "string", "minLength": 40, "maxLength": 250, "description": "这个方向如何撬动他已有的优势，附带具体行动项" }
            }
          }
        },
        "supplementarySuggestions": {
          "type": "object",
          "required": ["targetedTraining", "talentIncubator"],
          "description": "补充建议——成长建议（实战培训方向）+ 人才定制孵化器",
          "properties": {
            "targetedTraining": {
              "type": "string",
              "minLength": 60,
              "maxLength": 400,
              "description": "成长建议：实战培训方向——用'▎小标题'分段结构，含价值主张+2-3个具体培训方向，每项说明结业标准和对他的意义。"
            },
            "talentIncubator": {
              "type": "string",
              "minLength": 60,
              "maxLength": 400,
              "description": "人才定制孵化器建议——用'▎小标题'分段结构，含为什么传统就业太慢+会经历什么+为什么适合他。"
            }
          }
        },
        "stakeholderAdvice": { "type": "string", "minLength": 50, "maxLength": 400, "description": "与父辈及团队沟通建议——用直接建议的句式，至少覆盖父辈和团队两个对象。如：'对父辈：我需要亲手绘制一张行业地图，才能把家业带得更稳。' 不用'不要说/而是说'模板。" }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 60,
      "maxLength": 400,
      "description": "最后一面镜子——回顾他最亮眼的光芒+当前需补的短板+下一步。温暖有力的收尾。"
    }
  }
}
