  "scoring_rule": {
    "type": "additive",
    "dimensions": [
      {
        "key": "psychological_barrier",
        "name": "心理障碍（内在）",
        "min": 0,
        "max": 16,
        "description": "评估害怕批评、完美主义、自我怀疑、害怕失败等内在心理因素对创造力的阻碍。得分越高表示心理障碍越少。"
      },
      {
        "key": "cognitive_barrier",
        "name": "认知障碍",
        "min": 0,
        "max": 12,
        "description": "评估思维固化、过早评判、不能容忍模糊等认知模式对创造力的限制。得分越高表示认知障碍越少。"
      },
      {
        "key": "environmental_barrier",
        "name": "环境与资源障碍",
        "min": 0,
        "max": 20,
        "description": "评估时间不足、资源缺乏、环境不支持、知识储备不足等外部因素对创造力的制约。得分越高表示环境障碍越少。"
      }
